# Storacha CI credentials — generate once via:
#   storacha key create --json
#   storacha delegation create <did> --can 'space/blob/add' --can 'upload/add' --base64
ANCHR_STORACHA_KEY=
ANCHR_STORACHA_PROOF=

# Wallet that owns the .sol domain you're deploying to.
# Must be a JSON array of numbers (contents of a Solana CLI keypair file).
ANCHR_WALLET_SECRET_KEY=

# Optional — defaults to Solana mainnet-beta public RPC if unset.
# Use a devnet RPC here while testing (e.g. https://api.devnet.solana.com)
ANCHR_SOLANA_RPC_URL=

# Only needed if anchr.json has "provider": "filebase" (alternate to Storacha)
# Generate at: Filebase Console → Access Keys
ANCHR_FILEBASE_KEY=
ANCHR_FILEBASE_SECRET=
ANCHR_FILEBASE_BUCKET=
